# Hivemind credentials
# Copy this file to ~/.config/hivemind/env and chmod 600.
# Never commit a populated version of this file.

# Required — your Hivemind API key (format: hm_k_...).
# Request one at https://myosin.typeform.com/api-request
HIVEMIND_API_KEY=

# Optional — default project UUID used when a command accepts a project.
# Leave blank if you don't have a project yet; you can always pass
# --project <uuid> per-invocation or create one with `hivemind-project create`.
HIVEMIND_PROJECT_ID=

# Optional — override the API host. Defaults to https://hivemind.myosin.xyz
# HIVEMIND_API_URL=https://hivemind.myosin.xyz
